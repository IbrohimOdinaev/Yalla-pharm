{
  "Serilog": {
    "Using": [ "Serilog.Sinks.Console" ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.AspNetCore": "Warning"
      }
    },
    "Enrich": [ "FromLogContext" ],
    "WriteTo": [
      { "Name": "Console" }
    ]
  },

  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",

  "ConnectionStrings": {
    "Default": ""
  },

  "Database": {
    "ApplyMigrationsOnStartup": false,
    "ContainerHost": "yalla-postgres"
  },

  "Jwt": {
    "Issuer": "Yalla.Api",
    "Audience": "Yalla.Api.Client",
    "Key": "",
    "AccessTokenMinutes": 43200
  },

  "MinIo": {
    "Endpoint": "",
    "ContainerEndpoint": "",
    "AccessKey": "",
    "SecretKey": "",
    "BucketName": "",
    "UseSsl": false
  },

  "SmsVerification": {
    "RegistrationEnabled": true,
    "AllowRegistrationBypass": true,
    "CodeLength": 6,
    "CodeTtlMinutes": 10,
    "ResendCooldownSeconds": 60,
    "MaxVerificationAttempts": 5,
    "MaxResendCount": 5,
    "RequestRateLimitPerMinute": 20,
    "VerifyRateLimitPerMinute": 60,
    "ResendRateLimitPerMinute": 20,
    "CleanupIntervalMinutes": 15,
    "ExpiredSessionRetentionMinutes": 120,
    "CompletedSessionRetentionHours": 24,
    "MessageTemplate": "Код подтверждения Yalla Farm: {code}",
    "FixedCodeForTests": ""
  },

  "DushanbeCityPayment": {
    "BaseUrl": "",
    "ProviderName": "DushanbeCityManualPhone",
    "Currency": "TJS",
    "CreateOrderOnlyAfterAdminPaymentConfirmation": true,
    "PendingConfirmationTimeoutMinutes": 5,
    "CleanupIntervalSeconds": 30
  },

  "OsonSms": {
    "ApiBaseUrl": "https://api.osonsms.com",
    "AuthMode": "Hash",
    "Login": "",
    "Token": "",
    "Sender": "Yalla",
    "PassSaltHash": "",
    "Delimiter": ";",
    "T": "23",
    "IsConfidential": true,
    "UseStub": true,
    "TimeoutSeconds": 20,
    "MaxRetryAttempts": 2,
    "RetryBackoffSeconds": 2
  },

  "SmsOutbox": {
    "Enabled": true,
    "BatchSize": 50,
    "PollIntervalSeconds": 15,
    "MaxAttempts": 5,
    "RetryBackoffSeconds": 30,
    "RetentionDays": 7
  },

  "SmsTemplates": {
    "Provider": "OsonSms",
    "PaymentConfirmed": "Оплата подтверждена. Заказ {orderId} оформлен. Сумма: {amount} {currency}.",
    "OrderStatus": {
      "New": "Заказ {orderId} создан и ожидает подтверждения.",
      "UnderReview": "Заказ {orderId} принят и передан в обработку.",
      "Preparing": "Заказ {orderId} готовится аптекой.",
      "Ready": "Заказ {orderId} собран и готов к выдаче/доставке.",
      "OnTheWay": "Заказ {orderId} передан курьеру и в пути.",
      "Delivered": "Заказ {orderId} успешно доставлен.",
      "Cancelled": "Заказ {orderId} отменен.",
      "Returned": "Заказ {orderId} переведен в статус возврата."
    },
    "JuraDelivery": {
      "4": "Курьер на месте. Код для получения: {receiptCode}",
      "7": "Курьер везёт ваш заказ. Код для получения: {receiptCode}",
      "9": "Заказ доставлен. Спасибо за покупку!",
      "10": "Доставка заказа {orderId} отменена. Средства будут возвращены."
    }
  },

  "WooCommerce": {
    "BaseUrl": "",
    "ConsumerKey": "",
    "ConsumerSecret": "",
    "WebhookSecret": "",
    "PharmacyId": "",
    "PollIntervalMinutes": 10
  },

  "Jura": {
    "BaseUrl": "",
    "Login": "",
    "Password": "",
    "DivisionId": 6,
    "DefaultTariffId": 37
  },

  "Elasticsearch": {
    "Url": "",
    "MedicineIndex": "medicines"
  },

  "Telegram": {
    "BotToken": "",
    "BotUsername": "",
    "WebhookPublicBaseUrl": "",
    "WebhookSecretToken": "",
    "AuthSessionTtlSeconds": 300,
    "AutoRegisterWebhookOnStart": false
  },

  "Cors": {
    "AllowedOrigins": [
      "http://localhost:3000"
    ]
  }
}
