# ============================================
# Yalla Farm — environment template
# Copy to `.env.dev` for local docker-compose.dev.yml or `.env.prod` for
# the prod compose / Render dashboard. Never commit a filled-in copy.
#
# Required values are marked [REQUIRED] — the API refuses to start
# without them. Optional values degrade specific features when empty
# (you'll see a warning in the API startup log).
# ============================================


# ── PostgreSQL ──────────────────────────────────────────────────────
# [REQUIRED] Connection string consumed by EF Core / Npgsql.
DB_CONNECTION_STRING=Host=localhost;Port=5432;Database=app_db;Username=postgres;Password=postgres

# [REQUIRED at first deploy] Apply pending migrations on startup. Set to
# `false` once you switch to manual migration control.
DB_APPLY_MIGRATIONS=true

# Local-dev compose only — used by the `postgres` service to bootstrap.
POSTGRES_DB=app_db
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres


# ── S3 / MinIO ──────────────────────────────────────────────────────
# [REQUIRED] Object storage for medicine images + prescription scans.
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=yalla
# `true` for prod (HTTPS S3), `false` for local minio container.
MINIO_USE_SSL=false


# ── JWT ─────────────────────────────────────────────────────────────
# [REQUIRED] Random string of 32+ characters. Generate with
#   openssl rand -base64 48
# Never reuse a key across environments.
JWT_KEY=replace-me-with-a-strong-random-string-of-at-least-32-chars
JWT_ISSUER=Yalla.Api
JWT_AUDIENCE=Yalla.Api.Client
JWT_ACCESS_TOKEN_MINUTES=43200


# ── CORS ────────────────────────────────────────────────────────────
# [REQUIRED] At least one origin. Add the deployed front host(s).
CORS_ORIGIN_0=http://localhost:3000
CORS_ORIGIN_1=https://yalla-pharm.vercel.app


# ── Telegram bot (auth + notifications) ─────────────────────────────
# Optional. Without these, Telegram-login + status push are disabled.
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=
TELEGRAM_WEBHOOK_URL=
TELEGRAM_WEBHOOK_SECRET=
TELEGRAM_AUTO_REGISTER_WEBHOOK=false


# ── WooCommerce sync (catalog import + price/stock webhook) ─────────
# Optional. Without these, the WC poll service does nothing.
WOOCOMMERCE_BASE_URL=
WOOCOMMERCE_CONSUMER_KEY=
WOOCOMMERCE_CONSUMER_SECRET=
WOOCOMMERCE_WEBHOOK_SECRET=
WOOCOMMERCE_PHARMACY_ID=


# ── OsonSMS (OTP login + status SMS) ────────────────────────────────
# When `OSON_SMS_USE_STUB=true` SMS goes to the console; the rest of
# the values can stay empty. Production must set `_TOKEN`.
OSON_SMS_LOGIN=
OSON_SMS_TOKEN=
OSON_SMS_PASS_SALT_HASH=
OSON_SMS_USE_STUB=true


# ── DushanbeCity payment ────────────────────────────────────────────
# Optional. Empty → checkout / 3 TJS prescription fee fall back to
# manual SuperAdmin confirmation.
DC_PAYMENT_BASE_URL=


# ── JURA delivery ───────────────────────────────────────────────────
# Optional. Empty → delivery features (address search, courier
# tracking) are disabled.
JURA_BASE_URL=
JURA_LOGIN=
JURA_PASSWORD=


# ── Elasticsearch ───────────────────────────────────────────────────
# Optional. Empty → medicine search runs in degraded DB-LIKE mode.
ELASTICSEARCH_URL=http://localhost:9200
ELASTICSEARCH_INDEX=medicines


# ── Google Maps (frontend build arg) ────────────────────────────────
# Optional. Empty → pharmacy map + address picker disabled.
GOOGLE_MAPS_API_KEY=


# ── Frontend (Next.js build args / runtime env) ─────────────────────
# Pick ONE networking mode — at least one of these two must be set:
#
#   1. INTERNAL_API_URL (recommended for Vercel + Render):
#      Server-only var. `next.config.ts` rewrites /api/* and /hubs/* to
#      this host server-side. Browser uses relative URLs, so no CORS
#      is triggered and the API host never leaks into the bundle.
#
#   2. NEXT_PUBLIC_API_BASE_URL:
#      Bakes the absolute API host into the client bundle for direct
#      cross-origin calls. Requires Cors:AllowedOrigins on the API.
#
# Setting both is fine — the public var wins at runtime.
INTERNAL_API_URL=http://api:8080
NEXT_PUBLIC_API_BASE_URL=

NEXT_PUBLIC_SIGNALR_UPDATES_HUB_URL=/hubs/updates
NEXT_PUBLIC_SIGNALR_TELEGRAM_AUTH_HUB_URL=/hubs/telegram-auth
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=
NEXT_PUBLIC_YANDEX_MAPS_API_KEY=
