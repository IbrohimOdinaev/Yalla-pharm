{
  "Serilog": {
    "Using": [ "Serilog.Sinks.Console" ],
    "MinimumLevel": {
      "Default": "Debug",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.AspNetCore": "Warning"
      }
    },
    "Enrich": [ "FromLogContext" ],
    "WriteTo": [
      { "Name": "Console" }
    ]
  },

  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },

  "ConnectionStrings": {
    "Default": "Host=localhost;Port=5432;Database=app_db;Username=postgres;Password=postgres"
  },

  "Database": {
    "ApplyMigrationsOnStartup": false,
    "ContainerHost": "yalla-postgres"
  },

  "Jwt": {
    "Issuer": "Yalla.Api",
    "Audience": "Yalla.Api.Client",
    "Key": "ChangeThisJwtKey_ForDev_AtLeast_32Chars!",
    "AccessTokenMinutes": 43200
  },

  "MinIo": {
    "Endpoint": "localhost:9000",
    "ContainerEndpoint": "yalla-minio:9000",
    "AccessKey": "minioadmin",
    "SecretKey": "minioadmin",
    "BucketName": "yalla-farm-medicines",
    "UseSsl": false
  },

  "SmsVerification": {
    "RegistrationEnabled": true,
    "AllowRegistrationBypass": true,
    "CodeLength": 6,
    "CodeTtlMinutes": 10,
    "ResendCooldownSeconds": 60,
    "MaxVerificationAttempts": 5,
    "MaxResendCount": 5,
    "RequestRateLimitPerMinute": 20,
    "VerifyRateLimitPerMinute": 60,
    "ResendRateLimitPerMinute": 20,
    "CleanupIntervalMinutes": 15,
    "ExpiredSessionRetentionMinutes": 120,
    "CompletedSessionRetentionHours": 24,
    "MessageTemplate": "Код подтверждения Yalla Farm: {code}",
    "FixedCodeForTests": "111111"
  },

  "DushanbeCityPayment": {
    "BaseUrl": "http://pay.expresspay.tj/?A=9762000087892609&s=&c=&f1=133&FIELD2=&FIELD3=",
    "ProviderName": "DushanbeCityManualPhone",
    "Currency": "TJS",
    "PendingConfirmationTimeoutMinutes": 5,
    "CleanupIntervalSeconds": 30
  },

  "OsonSms": {
    "ApiBaseUrl": "https://api.osonsms.com",
    "Login": "yalla",
    "Token": "",
    "Sender": "Yalla",
    "IsConfidential": true,
    "UseStub": true,
    "TimeoutSeconds": 20
  }
}
