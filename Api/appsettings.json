{
  "Serilog": {
    "Using": [ "Serilog.Sinks.Console" ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.AspNetCore": "Warning"
      }
    },
    "Enrich": [ "FromLogContext" ],
    "WriteTo": [
      { "Name": "Console" }
    ]
  },

  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",

  "ConnectionStrings": {
    "Default": "Host=yalla-postgres;Port=5432;Database=app_db;Username=postgres;Password=postgres"
  },

  "Database": {
    "ApplyMigrationsOnStartup": false,
    "ContainerHost": "yalla-postgres"
  },

  "Jwt": {
    "Issuer": "Yalla.Api",
    "Audience": "Yalla.Api.Client",
    "Key": "ChangeThisJwtKey_ForDev_AtLeast_32Chars!",
    "AccessTokenMinutes": 43200
  },

  "MinIo": {
    "Endpoint": "yalla-minio:9000",
    "ContainerEndpoint": "yalla-minio:9000",
    "AccessKey": "minioadmin",
    "SecretKey": "minioadmin",
    "BucketName": "yalla-farm-medicines",
    "UseSsl": false
  },

  "SmsVerification": {
    "RegistrationEnabled": true,
    "AllowRegistrationBypass": true,
    "CodeLength": 6,
    "CodeTtlMinutes": 10,
    "ResendCooldownSeconds": 60,
    "MaxVerificationAttempts": 5,
    "MaxResendCount": 5,
    "RequestRateLimitPerMinute": 20,
    "VerifyRateLimitPerMinute": 60,
    "ResendRateLimitPerMinute": 20,
    "CleanupIntervalMinutes": 15,
    "ExpiredSessionRetentionMinutes": 120,
    "CompletedSessionRetentionHours": 24,
    "MessageTemplate": "Код подтверждения Yalla Farm: {code}",
    "FixedCodeForTests": ""
  },

  "DushanbeCityPayment": {
    "BaseUrl": "http://pay.expresspay.tj/?A=9762000087892609&s=&c=&f1=133&FIELD2=&FIELD3=",
    "ProviderName": "DushanbeCityManualPhone",
    "Currency": "TJS",
    "CreateOrderOnlyAfterAdminPaymentConfirmation": true,
    "PendingConfirmationTimeoutMinutes": 5,
    "CleanupIntervalSeconds": 30
  },

  "OsonSms": {
    "ApiBaseUrl": "https://api.osonsms.com",
    "AuthMode": "Hash",
    "Login": "yalla",
    "Token": "",
    "Sender": "Yalla",
    "PassSaltHash": "cc32eedb58a4166aa400974df4ada2c6",
    "Delimiter": ";",
    "T": "23",
    "IsConfidential": true,
    "UseStub": false,
    "TimeoutSeconds": 20,
    "MaxRetryAttempts": 2,
    "RetryBackoffSeconds": 2
  },

  "SmsOutbox": {
    "Enabled": true,
    "BatchSize": 50,
    "PollIntervalSeconds": 15,
    "MaxAttempts": 5,
    "RetryBackoffSeconds": 30,
    "RetentionDays": 7
  },

  "SmsTemplates": {
    "Provider": "OsonSms",
    "PaymentConfirmed": "Оплата подтверждена. Заказ {orderId} оформлен. Сумма: {amount} {currency}.",
    "OrderStatus": {
      "New": "Заказ {orderId} создан и ожидает подтверждения.",
      "UnderReview": "Заказ {orderId} принят и передан в обработку.",
      "Preparing": "Заказ {orderId} готовится аптекой.",
      "Ready": "Заказ {orderId} собран и готов к выдаче/доставке.",
      "OnTheWay": "Заказ {orderId} передан курьеру и в пути.",
      "Delivered": "Заказ {orderId} успешно доставлен.",
      "Cancelled": "Заказ {orderId} отменен.",
      "Returned": "Заказ {orderId} переведен в статус возврата."
    }
  },

  "Cors": {
    "AllowedOrigins": [
      "http://localhost:3000",
      "http://127.0.0.1:3000"
    ]
  }
}
